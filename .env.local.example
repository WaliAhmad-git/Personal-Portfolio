# ═══════════════════════════════════════════════════════════
# .env.local — Server-only secrets (NEVER commit this file)
# Add to .gitignore immediately. Set these in Vercel dashboard
# under Settings → Environment Variables for production.
# ═══════════════════════════════════════════════════════════

# Formspree endpoint — server-only (no NEXT_PUBLIC_ prefix)
# This prevents the endpoint ID from appearing in client JS bundles.
FORMSPREE_ENDPOINT=https://formspree.io/f/mkoadnwr

# Your production site URL (used for CSRF origin check in /api/contact)
NEXT_PUBLIC_SITE_URL=https://wali-portfolio.vercel.app
# Update to your custom domain once you get it:
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
